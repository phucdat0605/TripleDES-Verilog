`timescale 1ns / 1ps

module tripleDES_tb;

    reg         clock;
    reg         rst;
    reg         start;
    reg  [63:0] key0;
    reg  [63:0] key1;
    reg  [63:0] key2;
    reg  [63:0] plaintext_in;
    
    wire [63:0] ciphertext_out;
    wire [63:0] recovered_out;
    wire        done_all;

    tripleDES uut (
        .clock(clock),
        .rst(rst),
        .start(start),
        .key0(key0),
        .key1(key1),
        .key2(key2),
        .plaintext_in(plaintext_in),
        .ciphertext_out(ciphertext_out),
        .recovered_out(recovered_out),
        .done_all(done_all)
    );

    initial begin
        clock = 0;
        forever #5 clock = ~clock; 
    end

    initial begin
	 //CASE 1
        rst = 1;
        start = 0;
        key0 = 64'h133457799BBCDFF1; 
        key1 = 64'h1122334455667788;
        key2 = 64'h7766554433221100;
        plaintext_in = 64'h0123456789ABCDEF;

        #25 rst = 0;
        #20;

        @(posedge clock);
        start = 1;     
        @(posedge clock);
        start = 0;     
        $display("Plaintext          : %h", plaintext_in);
        wait(done_all == 1);
        
        #10; 
    
        $display("Ciphertext         : %h", ciphertext_out);
        $display("Plaintext khoi phuc: %h", recovered_out);
		  $display("--------------------------------------------");
        
        // Tự động kiểm tra tính đúng đắn
        if (plaintext_in == recovered_out) begin
            $display("Self_checking: Du lieu trung khop");
        end else begin
            $display("Self_checking: Du lieu bi sai lech");
        end
        $display("--------------------------------------------");

        #100;
        $stop;
    end

endmodule